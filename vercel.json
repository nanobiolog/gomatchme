{
  "version": 2,
  "builds": [
    {
      "src": "app.mjs",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/scrape",
      "methods": ["POST"],
      "dest": "app.mjs"
    },
    {
      "src": "/(.*)",
      "dest": "/public/$1"
    },
    {
      "src": "/(.*)",
      "dest": "app.mjs"
    }
  ]
}
